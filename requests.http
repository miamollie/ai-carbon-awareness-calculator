# Carbon Calculator request collection
# Usage in VS Code REST Client:
# 0) Start local API: npm run sam:local
# 1) Update local and prod base URLs
# 2) Initialize MCP with POST /mcp (initialize request), then copy `mcp-session-id` response header into @mcpSessionId
# 3) Send subsequent POST/GET/DELETE /mcp requests with the same `mcp-session-id` header
# Public demo: no API key is required for any route.
# NOTE: Do not set a custom `Host` header; API Gateway returns 403 for invalid host.

@contentType = application/json
@localBaseURL = http://localhost:3000
@prodBaseURL = https://bo6q5pon14.execute-api.eu-north-1.amazonaws.com
@mcpSessionId = replace-after-calling-mcp-get

### --------------------------------------------------------
### LOCAL REST REQUESTS
### --------------------------------------------------------

### Local REST health check
GET {{localBaseURL}}/health
Accept: {{contentType}}

### Local REST carbon calculation
POST {{localBaseURL}}/carbon
Content-Type: {{contentType}}

{
  "model": "claude-sonnet-4.6",
  "input_tokens": 50000,
  "output_tokens": 25000
}

### Local REST validation failure (unknown model)
POST {{localBaseURL}}/carbon
Content-Type: {{contentType}}

{
  "model": "invalid-model",
  "input_tokens": 2000,
  "output_tokens": 300
}

### Local REST invalid payload (missing required token fields)
POST {{localBaseURL}}/carbon
Content-Type: {{contentType}}

{
  "model": "claude-sonnet-4.6"
}

### --------------------------------------------------------
### LOCAL MCP (STREAMABLE HTTP) REQUESTS
### --------------------------------------------------------

### Local MCP health
GET {{localBaseURL}}/mcp-health
Accept: {{contentType}}

### Local MCP initialize session (run this first; copy mcp-session-id response header)
POST {{localBaseURL}}/mcp
Content-Type: {{contentType}}

{
  "jsonrpc": "2.0",
  "id": 0,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": {
      "name": "rest-client",
      "version": "1.0.0"
    }
  }
}

### Local MCP optional stream connect (requires mcp-session-id header)
GET {{localBaseURL}}/mcp
Accept: text/event-stream
mcp-session-id: {{mcpSessionId}}

### Local MCP list tools
POST {{localBaseURL}}/mcp
Content-Type: {{contentType}}
mcp-session-id: {{mcpSessionId}}

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "tools/list",
  "params": {}
}

### Local MCP call calculate_emissions
POST {{localBaseURL}}/mcp
Content-Type: {{contentType}}
mcp-session-id: {{mcpSessionId}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {
    "name": "calculate_AI_carbon_emissions",
    "arguments": {
      "model": "claude-opus-4.6",
      "input_tokens": 12000,
      "output_tokens": 6000
    }
  }
}

### Local MCP invalid session check
POST {{localBaseURL}}/mcp
Content-Type: {{contentType}}
mcp-session-id: bad-session

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/list",
  "params": {}
}

### Local MCP terminate session
DELETE {{localBaseURL}}/mcp
mcp-session-id: {{mcpSessionId}}

### --------------------------------------------------------
### PRODUCTION REQUESTS
### --------------------------------------------------------

### Production REST health check
GET {{prodBaseURL}}/health
Accept: {{contentType}}

### Production REST carbon calculation
POST {{prodBaseURL}}/carbon
Content-Type: {{contentType}}

{
  "model": "claude-sonnet-4.6",
  "input_tokens": 85000,
  "output_tokens": 40000
}

### Production MCP health check
GET {{prodBaseURL}}/mcp-health
Accept: {{contentType}}

### Production MCP initialize session (run first; copy mcp-session-id response header)
POST {{prodBaseURL}}/mcp
Content-Type: {{contentType}}

{
  "jsonrpc": "2.0",
  "id": 10,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": {
      "name": "rest-client",
      "version": "1.0.0"
    }
  }
}

### Production MCP optional stream connect (requires mcp-session-id header)
GET {{prodBaseURL}}/mcp
Accept: text/event-stream
mcp-session-id: {{mcpSessionId}}

### Production MCP list tools
POST {{prodBaseURL}}/mcp
Content-Type: {{contentType}}
mcp-session-id: {{mcpSessionId}}

{
  "jsonrpc": "2.0",
  "id": 11,
  "method": "tools/list",
  "params": {}
}

### Production MCP call calculate_emissions
POST {{prodBaseURL}}/mcp
Content-Type: {{contentType}}
mcp-session-id: {{mcpSessionId}}

{
  "jsonrpc": "2.0",
  "id": 12,
  "method": "tools/call",
  "params": {
    "name": "calculate_AI_carbon_emissions",
    "arguments": {
      "model": "claude-haiku-4.5",
      "input_tokens": 5000,
      "output_tokens": 1200
    }
  }
}

### Production MCP terminate session
DELETE {{prodBaseURL}}/mcp
mcp-session-id: {{mcpSessionId}}
