{
  "name": "carbon-calc",
  "version": "0.1.0",
  "private": true,
  "description": "Single-region CDK MVP for Lambda carbon calculator",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "mcp:lambda": "node -e \"require('./dist/src/mcp/mcp-lambda.js')\"",
    "cdk:synth": "cdk synth",
    "sam:prepare": "npm run build && npm run cdk:synth",
    "sam:local": "npm run sam:prepare && sam local start-api -t cdk.out/CarbonCalcSingleRegion.template.json --port 3000",
    "cdk:diff": "cdk diff",
    "cdk:bootstrap": "cdk bootstrap",
    "cdk:deploy": "cdk deploy --all --require-approval never",
    "cdk:destroy": "cdk destroy",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/express": "^5.0.6",
    "@types/node": "^22.9.0",
    "aws-cdk": "^2.170.0",
    "esbuild": "^0.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^4.17.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "source-map-support": "^0.5.21",
    "zod": "^4.1.12"
  }
}